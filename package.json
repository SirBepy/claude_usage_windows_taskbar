{
  "name": "claude-usage-taskbar-tool",
  "version": "1.0.47",
  "description": "Claude Usage Taskbar Tool",
  "main": "main.js",
  "author": "SirBepy",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "dist": "electron-builder",
    "dist:publish": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "sql.js": "^1.10.0"
  },
  "devDependencies": {
    "electron": ">=28.0.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.aiusage.toolbar",
    "productName": "Claude Usage Taskbar Tool",
    "win": {
      "target": "nsis",
      "artifactName": "Claude.Usage.Taskbar.Tool.Setup.${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "shortcutName": "Claude Usage Taskbar Tool",
      "include": "build/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "SirBepy",
      "repo": "claude_usage_in_taskbar"
    },
    "files": [
      "main.js",
      "src/**",
      "README.md",
      "CLAUDE.md",
      "node_modules/**",
      "!node_modules/**/{CHANGELOG.md,README.md,readme.md,Readme.md}",
      "!node_modules/**/test{,s}/**",
      "!node_modules/.bin"
    ],
    "asarUnpack": [
      "node_modules/sql.js/**"
    ]
  }
}
