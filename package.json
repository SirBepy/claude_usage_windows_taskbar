{
  "name": "claude-usage-taskbar-tool",
  "version": "1.0.0",
  "description": "System tray app to monitor Claude AI usage",
  "main": "main.js",
  "author": "SirBepy",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "dist": "electron-builder",
    "dist:publish": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "sql.js": "^1.10.0"
  },
  "devDependencies": {
    "electron": ">=28.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.aiusage.toolbar",
    "productName": "Claude Usage Taskbar Tool",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "shortcutName": "Claude Usage Taskbar Tool"
    },
    "publish": {
      "provider": "github",
      "owner": "SirBepy",
      "repo": "ai_usage"
    },
    "files": [
      "main.js",
      "src/**",
      "profile-preload.js",
      "profile-picker.html",
      "node_modules/**",
      "!node_modules/**/{CHANGELOG.md,README.md,readme.md,Readme.md}",
      "!node_modules/**/test{,s}/**",
      "!node_modules/.bin"
    ],
    "asarUnpack": [
      "node_modules/sql.js/**"
    ]
  }
}
